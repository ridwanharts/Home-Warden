{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile in the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique Google user ID" },
        "email": { "type": "string", "description": "Email address of the user" },
        "displayName": { "type": "string", "description": "Display name of the user" },
        "photoURL": { "type": "string", "description": "Profile picture URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of profile creation" }
      },
      "required": ["uid", "email"]
    },
    "MaintenanceZone": {
      "title": "MaintenanceZone",
      "description": "Home zone for tracking health score and task lists",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Zone unique ID" },
        "name": { "type": "string", "description": "Name of the zone (e.g., Interior, Eksterior)" },
        "score": { "type": "number", "description": "Operational score of this zone (0-100)" },
        "lastMaintained": { "type": "string", "format": "date-time", "description": "ISO string of the last maintenance completed" },
        "intervalMonths": { "type": "number", "description": "Target cycle interval in months between inspections" },
        "tasks": {
          "type": "array",
          "description": "List of core checklist task descriptions"
        }
      },
      "required": ["id", "name", "score", "lastMaintained", "intervalMonths", "tasks"]
    },
    "InventoryItem": {
      "title": "InventoryItem",
      "description": "Item stored in the home warehouse inventory",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique SKU or item ID" },
        "name": { "type": "string", "description": "Human-readable name of the item" },
        "category": { "type": "string", "description": "Item category classification" },
        "type": { "type": "string", "enum": ["Tool", "Consumable"], "description": "Kind of resource" },
        "quantity": { "type": "number", "description": "Stock count" },
        "unit": { "type": "string", "description": "Quantity metric (e.g., Units, Roll, Pcs)" },
        "health": { "type": "number", "description": "Condition status from 0 to 100" },
        "lastUpdated": { "type": "string", "format": "date-time", "description": "ISO timestamp of the last modification" }
      },
      "required": ["id", "name", "category", "type", "quantity", "unit", "health", "lastUpdated"]
    },
    "RepairDiagnosis": {
      "title": "RepairDiagnosis",
      "description": "A generated repair diagnosis provided by DIY repair mentor",
      "type": "object",
      "properties": {
        "problem": { "type": "string", "description": "The description inputted by the user" },
        "diagnosis": { "type": "string", "description": "The tech explanation generated by the system" },
        "shoppingList": { "type": "array", "description": "Required materials list" },
        "toolsNeeded": { "type": "array", "description": "Required tools list" },
        "steps": { "type": "array", "description": "Sequential steps to troubleshoot" },
        "safetyWarning": { "type": "string", "description": "Optional safety precautions" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When this was diagnosed" }
      },
      "required": ["problem", "diagnosis", "shoppingList", "toolsNeeded", "steps", "timestamp"]
    },
    "HouseRoom": {
      "title": "HouseRoom",
      "description": "A physical room in the house containing items to inspect",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Room unique ID" },
        "name": { "type": "string", "description": "Name of the room" },
        "type": { "type": "string", "description": "Type/category of the room" },
        "items": { "type": "array", "description": "List of physical items inside the room" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of creation" }
      },
      "required": ["id", "name", "type", "items", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Specific user master document pointer"
    },
    "users/{userId}/zones/{zoneId}": {
      "schema": "MaintenanceZone",
      "description": "User specific home repair maintenance zones"
    },
    "users/{userId}/inventory/{itemId}": {
      "schema": "InventoryItem",
      "description": "User specific item and parts stock"
    },
    "users/{userId}/history/{historyId}": {
      "schema": "RepairDiagnosis",
      "description": "History of AI-powered diagnostic sessions"
    },
    "users/{userId}/rooms/{roomId}": {
      "schema": "HouseRoom",
      "description": "User specific rooms configuration and item lists"
    }
  }
}
